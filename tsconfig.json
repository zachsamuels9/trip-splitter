{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM", "WebWorker"],
    "skipLibCheck": true
  },
  "include": ["*.js", "api/**/*.js", "lib/**/*.js", "scripts/**/*.mjs"]
}
